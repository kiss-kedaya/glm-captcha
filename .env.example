# 选择用于注册邮箱的提供商: mailtm 或 duckmail
MAIL_PROVIDER=mailtm

# Mail.tm API 基地址
MAILTM_API_BASE=https://api.mail.tm

# DuckMail API 基地址
DUCKMAIL_API_BASE=https://api.duckmail.sbs

# DuckMail Bearer Token（如服务端要求鉴权则填写）
DUCKMAIL_BEARER_TOKEN=

# 提交后若出现“验证失败，请重试”时的最大重试次数（>=1）
SUBMIT_RETRY_COUNT=3

# 等待注册邮件中验证链接的最长时长（秒，>=1）
MAIL_VERIFY_TIMEOUT_SECONDS=120

# 邮箱轮询间隔（秒，>=1）
MAIL_POLL_INTERVAL_SECONDS=3
